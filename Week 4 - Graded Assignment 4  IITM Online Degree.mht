                <div><link href="https://seek.onlinedegree.iitm.ac.in/static/codemirror/lib/codemirror.css" rel="stylesheet"><link href="https://seek.onlinedegree.iitm.ac.in/modules/code_tags/resources/code_tags.css" rel="stylesheet"></div><code class="codemirror-container-readonly" data-mode="python">def poly_zeros(L, a, b):
